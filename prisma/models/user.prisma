model User {
    id        Int        @id @default(autoincrement())
    name      String
    email     String     @unique
    password  String
    role      Role       @default(USER)
    phone     String?
    picture   String?
    status    UserStatus @default(ACTIVE)
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    @@map("users")
}